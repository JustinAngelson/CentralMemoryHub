              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "status": {
                      "type": "string",
                      "description": "Overall health status (healthy, degraded, or error)"
                    },
                    "time": {
                      "type": "string",
                      "description": "ISO timestamp of the health check"
                    },
                    "components": {
                      "type": "object",
                      "properties": {
                        "database": {
                          "type": "string",
                          "description": "Database status (up or down)"
                        },
                        "vector_db": {
                          "type": "string",
                          "description": "Vector database status (up or down)"
                        },
                        "api": {
                          "type": "string",
                          "description": "API status (up or down)"
                        }
                      }
                    },
                    "version": {
                      "type": "string",
